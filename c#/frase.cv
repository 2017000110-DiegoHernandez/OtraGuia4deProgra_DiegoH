internal class Program
{
    private static void Main(string[] args)
    {
        string a, b;

        int i;
        Console.WriteLine("Ingrese su frase");
        a = Console.ReadLine();
        b = "";

        for (i = a.Length - 1; i >= 0; i--)
        {
           
            b = b + a[i];
        }

    

        Console.WriteLine("Frase invertida: " + b);
    
}
}
