Algoritmo temperatura
	
	Escribir "Ingrese una temperatura en grados centígrados: "
	Leer temp
	
	f = (temp * (9/5)) + 32
	k = temp + 273.15
	
	Escribir "Su temperatura es: ", temp, " grados celcius"
	Escribir "Son ", f, " grados farenheit"
	Escribir "Son ", k, " grados kelvin"
	
FinAlgoritmo
